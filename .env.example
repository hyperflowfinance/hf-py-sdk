# Example environment configuration for the HyperFlow SDK.
# Copy to ".env" and fill in your values, then export them into your shell
# (the SDK reads these via os.environ; load .env with your preferred tool).

# GraphQL endpoint. Defaults to the Ethereum deployment if unset.
HYPERFLOW_API_URL=https://api.hyperflowlabs.com/ethereum/graphql

# Authentication header. Defaults to "Authorization" if a value is set.
HYPERFLOW_AUTH_HEADER=x-api-key
HYPERFLOW_AUTH_VALUE=YOUR_TOKEN
